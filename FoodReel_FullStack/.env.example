# MongoDB
MONGODB_URI=mongodb://localhost:27017/foodreel

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# ImageKit (video uploads) - https://imagekit.io
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# Razorpay (payments) - https://dashboard.razorpay.com
# Use test keys (rzp_test_...) for development
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=3000
NODE_ENV=development
